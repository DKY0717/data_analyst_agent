# OpenAI-compatible LLM API Configuration
# 变量名历史沿用 QWEN_*，但支持所有 OpenAI Chat Completions 兼容服务。
# 请根据自己已有的模型资源，任选一组取消注释并填写 API Key；不要同时启用多组。

# 方案一：Qwen / 阿里云百炼（北京地域）
# QWEN_API_KEY=your_api_key_here
# QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# QWEN_MODEL=qwen-plus

# 方案二：DeepSeek 官方 API
# QWEN_API_KEY=your_api_key_here
# QWEN_API_URL=https://api.deepseek.com/chat/completions
# QWEN_MODEL=deepseek-chat

# 方案三：小米 MiMo 按量付费
# QWEN_API_KEY=your_api_key_here
# QWEN_API_URL=https://api.xiaomimimo.com/v1/chat/completions
# QWEN_MODEL=mimo-v2.5-pro
# MiMo Token Plan 用户：请把上面的 URL 替换为控制台提供的专属完整 Chat Completions 地址。

# 可选：每百万输入/输出 Token 单价；留空时只统计 Token，不估算金额
QWEN_INPUT_PRICE_PER_MILLION_TOKENS=
QWEN_OUTPUT_PRICE_PER_MILLION_TOKENS=

# Database Configuration
# 支持两种后端: duckdb (嵌入式) 或 postgresql (生产级)
DATABASE_URL=duckdb:///./data/database.duckdb
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/data_analyst_agent
# DATABASE_BACKEND=postgresql

# PostgreSQL Configuration (仅 DATABASE_BACKEND=postgresql 时生效)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=data_analyst_agent

# Application Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
# demo 允许无认证本地展示；secure 会在 readiness 强制认证、沙箱和关闭 Demo Auth
DEPLOYMENT_PROFILE=demo
# 逗号分隔的前端来源；生产部署请改成真实域名，避免使用 *
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SQL Configuration
SQL_TIMEOUT=30
SQL_MAX_ROWS=1000
SQL_MAX_RETRIES=3
# SQL 执行沙箱（安全默认；仅本地调试时显式改为 false）
SANDBOX_MODE=true

# Authentication (可选，未配置时所有请求自动放行)
# JWT_SECRET=replace-with-at-least-32-random-characters
# API_KEYS=sk-key1,sk-key2,sk-key3
# JWT_EXPIRE_SECONDS=86400
# Demo Auth（仅本地演示使用；生产环境保持 false）
# AUTH_DEMO_ENABLED=false
# Password Auth（默认关闭；仅在可信本地或受控部署中显式配置）
# AUTH_PASSWORD_LOGIN_ENABLED=false
# AUTH_ADMIN_USERNAME=
# AUTH_ADMIN_PASSWORD=

# Optional data permission policy override. Empty uses backend/app/security/data_permissions.yaml
# DATA_PERMISSION_POLICY_PATH=

# Rate Limiting (可选，有默认值)
# RATE_LIMIT_DEFAULT=30/minute
# RATE_LIMIT_QUERY=10/minute
# RATE_LIMIT_AUTH=5/minute

# OpenTelemetry (可选)
# OTEL_EXPORTER=none  # 可选 console / otlp；默认 none，避免日志噪声
# OTEL_ENDPOINT=http://localhost:4317
